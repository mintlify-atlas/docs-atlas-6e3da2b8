  "keyFeatures": [
    "7TV name paints with gradient and shadow rendering",
    "7TV personal emotes per user",
    "7TV animated profile avatars in usercards",
    "4x high-resolution image support for 7TV and FFZ emotes",
    "Experimental Kick platform support",
    "Lua plugin system with HTTP/WebSocket/file I/O APIs",
    "Multi-platform support (Windows, macOS, Linux, FreeBSD, ARM)",
    "AVIF image format support",
    "Split-based multi-channel chat layout",
    "BetterTTV, FrankerFaceZ, and 7TV emote integration"
  ],
  "publicApiSurface": [
